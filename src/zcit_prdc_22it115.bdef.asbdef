projection;
strict ( 2 );
use draft;

define behavior for ZCIT_PRDC_22IT115 alias ProductHdr
{
  use create;
  use update;
  use delete;
  use action Edit;
  use action Activate;
  use action Discard;
  use action Prepare;
  use action Resume;
  use association _LifecycleStage { create; with draft; }
}

define behavior for ZCIT_LSTC_22IT115 alias LifecycleStage
{
  use update;
  use delete;
  use association _ProductHeader { with draft; }
}